generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  DISABLED
  SUSPENDED
}

enum SubscriptionType {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

model Tenant {
  id               String           @id @default(uuid())
  tenantCode       String           @unique
  name             String
  companyName      String
  domainName       String
  status           TenantStatus     @default(ACTIVE)
  subscriptionType SubscriptionType @default(BASIC)

  // Basic Settings
  timeZone      String?
  country       String?
  currency      String?
  contactEmail  String?
  contactMobile String?
  logoUrl       String?
  faviconUrl    String?

  // Relations
  m365Settings   M365Settings?
  adSettings     AdSettings?
  smtpSettings   SmtpSettings?
  authSettings   AuthSettings?
  offices        Office[]
  departments    Department[]
  roles          Role[]
  auditLogs      AuditLog[]
  emailTemplates EmailTemplate[]
  users          User[]

  // Audit Columns
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  @@map("tenants")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  roleId   String?
  role     Role?   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model M365Settings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  azureTenantId   String?
  clientId        String?
  clientSecret    String? // Should be encrypted
  redirectUrl     String?
  microsoftDomain String?
  graphApiStatus  String?

  updatedAt DateTime @updatedAt

  @@map("m365_settings")
}

model AdSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  adServerIp   String?
  domainName   String?
  ldapPath     String?
  baseDn       String?
  bindUsername String?
  bindPassword String? // Should be encrypted
  sslEnabled   Boolean @default(false)
  port         Int     @default(389)

  updatedAt DateTime @updatedAt

  @@map("ad_settings")
}

model SmtpSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  host        String?
  port        Int     @default(587)
  senderEmail String?
  senderName  String?
  username    String?
  password    String? // Should be encrypted
  sslEnabled  Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("smtp_settings")
}

model AuthSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  ssoEnabled       Boolean  @default(false)
  enforceM365Login Boolean  @default(false)
  sessionTimeout   Int      @default(3600)
  mfaEnforced      Boolean  @default(false)
  allowedDomains   String[]

  // Password Policy
  minCharacters    Int     @default(12)
  requireUppercase Boolean @default(true)
  requireLowercase Boolean @default(true)
  requireNumbers   Boolean @default(true)
  requireSymbols   Boolean @default(true)
  expiryDays       Int     @default(90)

  updatedAt DateTime @updatedAt

  @@map("auth_settings")
}

model Office {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name      String
  address   String?
  city      String?
  state     String?
  zipCode   String?
  country   String?
  latitude  Float?
  longitude Float?
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("offices")
}

model Department {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name   String
  status String @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

model Role {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name        String
  permissions String[] // Array of permission strings
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model AuditLog {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  userId    String?
  module    String
  action    String
  details   Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model EmailTemplate {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name      String
  subject   String?
  body      String? // HTML content
  variables String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}
